<!DOCTYPE html>
<html>
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link rel="stylesheet" href="/css/style.css">

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

<style>

/* ===== MOBILE FIRST ===== */

body{
  margin:0;
  padding:0 12px;
  font-family:'Inter',sans-serif;
  background:#f3f4f6;
}

/* HEADER */
.header{
  padding:14px 12px;
}
*{
  box-sizing: border-box;
}
.header-left{
  display:flex;
  align-items:center;
  gap:10px;
}

.logo-icon{
  width:34px;
  height:34px;
  background:#2563eb;
  border-radius:50%;
  display:flex;
  align-items:center;
  justify-content:center;
  color:white;
  font-size:16px;
}

.header h1{
  font-size:16px;
  margin:0;
}

.header p{
  font-size:12px;
  margin:0;
  color:#6b7280;
}

/* PAGE */
.page{
  padding:16px 0;
  display:flex;
  justify-content:center;
}

/* CARD */
.form-card{
  width:100%;
  max-width:520px;
  background:white;
  padding:20px;
  border-radius:14px;
  box-shadow:0 5px 20px rgba(0,0,0,0.08);
}

.form-card h2{
  font-size:16px;
  margin-bottom:14px;
}

/* INPUTS */
label{
  display:block;
  font-size:13px;
  font-weight:500;
  margin-top:12px;
}
input,select,textarea{
  width:100%;
  padding:12px;
  border:1px solid #e5e7eb;
  border-radius:8px;
  font-size:14px;
  margin-top:6px;
}

textarea{
  resize:none;
}

/* GRID */
.grid3{
  display:grid;
  grid-template-columns:1fr;
  gap:10px;
}

.grid3{
  display:grid;
  grid-template-columns:1fr;
  gap:12px;
}

@media(min-width:768px){
  .grid3{
    grid-template-columns:1fr 1fr 1fr;
  }
}
/* Desktop */
@media(min-width:768px){
  .grid3{
    grid-template-columns:1fr 1fr 1fr;
  }
}

/* PHOTO */
.photo-row{
  display:flex;
  gap:12px;
  align-items:center;
  flex-wrap:wrap;
}

.photo-box{
  width:90px;
  height:110px;
  border:2px dashed #d1d5db;
  border-radius:10px;
  display:flex;
  align-items:center;
  justify-content:center;
  background:#f9fafb;
  overflow:hidden;
}

.photo-box img{
  width:100%;
  height:100%;
  object-fit:cover;
}

/* BUTTONS */
.upload-btn{
  display:inline-flex;
  align-items:center;
  gap:6px;
  background:#111827;
  color:white;
  padding:8px 14px;
  border-radius:8px;
  font-size:13px;
  cursor:pointer;
}

.submit-btn{
  margin-top:18px;
  width:100%;
  padding:12px;
  border:none;
  border-radius:10px;
  background:#2563eb;
  color:white;
  font-size:14px;
  font-weight:500;
  cursor:pointer;
}

/* FOOTER */
footer{
  text-align:center;
  font-size:12px;
  color:#6b7280;
  margin:20px 0;
}

</style>

</head>

<body>

 
<a href="/" style="text-decoration:none; color:inherit;">
<header class="header">

<div class="header-left">

<div class="logo-icon">
🎓
</div>

<div>
<h1>School ID Card Generator</h1>
<p>Generate your student identity card</p>
</div>

</div>

</header>

<div class="page">

<div class="form-card">

<h2>Student Information</h2>

<form action="/preview" method="POST" enctype="multipart/form-data">

<label>Student Photo</label>

<div class="photo-row">

<div class="photo-box">

<% if (typeof data !== "undefined" && data.photo) { %>

<img src="/uploads/<%= data.photo %>" id="previewImg" style="display:block">

<% } else { %>

<img id="previewImg" style="display:none">

<div id="photoPlaceholder">📷</div>

<% } %>

</div>

<label class="upload-btn">
Upload
<input type="file" name="photo" id="photoInput" hidden required>
</label>

</div>

<label>Full Name</label>
<input name="name" 
required
value="<%= typeof data !== 'undefined' ? data.name : '' %>"
maxlength="30" 
oninput="this.value = this.value.slice(0,30)">

<div class="grid3">

<div>
<label>Class</label>
<select name="class">
<option>Select</option>
<option>M1</option>
<option>M2</option>
<option>M3</option>
<% for(let i=1;i<=12;i++){ %>
<option value="<%= i %>" <%= (typeof data !== 'undefined' && data.class == i) ? 'selected' : '' %>>
<%= i %>
</option>
<% } %>
</select>
</div>

<div>
<label>Section</label>
<select name="section">
<option>Select</option>
<% ['Section A','Section B','Section C','Section D','Section E'].forEach(function(sec){ %>
<option value="<%= sec %>" <%= (typeof data !== 'undefined' && data.section == sec) ? 'selected' : '' %>>
<%= sec %>
</option>
<% }) %>
</select>
</div>

<div>
<label>Roll No</label>
<input name="roll"
value="<%= typeof data !== 'undefined' ? data.roll : '' %>">
</div>

</div>

<label>House Colour</label>
<select name="house" required>
<option>Select House Colour</option>

<% ['RED','GREEN','BLUE','YELLOW'].forEach(function(h){ %>
<option value="<%= h %>" <%= (typeof data !== 'undefined' && data.house == h) ? 'selected' : '' %>>
<%= h %>
</option>
<% }) %>

</select>

<label>Blood Group</label>
<select name="blood">
<option>Select</option>
<% ['A+','A-','B+','B-','AB+','AB-','O+','O-'].forEach(function(bg){ %>
<option value="<%= bg %>" <%= (typeof data !== 'undefined' && data.blood == bg) ? 'selected' : '' %>>
<%= bg %>
</option>
<% }) %>
</select>

<label>Mother's Name</label>
<input name="mother"
value="<%= typeof data !== 'undefined' ? data.mother : '' %>"
maxlength="20" 
oninput="this.value = this.value.slice(0,20)">

<label>Father's Name</label>
<input name="father"
value="<%= typeof data !== 'undefined' ? data.father : '' %>"
maxlength="20" 
oninput="this.value = this.value.slice(0,20)">

<label>Contact</label>
<input type="tel" name="contact" required
maxlength="10" 
oninput="this.value = this.value.slice(0,10)"
pattern="[0-9]{10}"
value="<%= typeof data !== 'undefined' ? data.contact : '' %>">

<label>Address</label>
<textarea 
name="address"
maxlength="100"
oninput="this.value = this.value.slice(0,100)"
><%= typeof data !== 'undefined' ? data.address : '' %></textarea>

<% if (typeof data !== "undefined" && data.photo) { %>
<input type="hidden" name="photo" value="<%= data.photo %>">
<% } %>

<button class="submit-btn">
Preview ID Card
</button>

</form>

</div>

</div>

<footer>
© 2026 school id system- St. Xaviers, Bhubaneswar
</footer>

<script src="/js/photoPreview.js"></script>

</body>
</html>