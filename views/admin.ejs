<!DOCTYPE html>
<html>
<head>
  <title>Admin Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 p-6">

<div class="max-w-7xl mx-auto">

  <!-- HEADER -->
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Admin Dashboard</h1>

    <a href="/admin/download-all" class="bg-blue-600 text-white px-4 py-2 rounded-lg shadow">
      Download All PDFs
    </a>
  </div>

  <!-- FILTERS -->
  <form method="GET" class="bg-white p-4 rounded-xl shadow mb-6 flex gap-4 flex-wrap">

    <input 
      type="text" 
      name="search" 
      placeholder="Search by name"
      value="<%= filters.search || '' %>"
      class="border p-2 rounded w-60"
    >

    <select name="class" class="border p-2 rounded">
      <option value="">All Classes</option>
      <option value="M1">M1</option>
      <option value="M2">M2</option>
      <option value="M3">M3</option>
      <option value="1">1</option>
      <option value="2">2</option>
      <option value="3">3</option>
      <option value="4">4</option>
      <option value="5">5</option>
      <option value="6">6</option>
      <option value="7">7</option>
      <option value="8">8</option>
      <option value="9">9</option>
      <option value="10">10</option>
      <option value="11">11</option>
      <option value="12">12</option>

    </select>

    <select name="section" class="border p-2 rounded">
      <option value="">All Sections</option>
      <option value="A">A</option>
      <option value="B">B</option>
      <option value="C">C</option>
      <option value="D">D</option>
      <option value="E">E</option>
    </select>

     <select name="house" class="border p-2 rounded">
      <option value="">All Houses</option>
      <option value="RED">RED</option>
      <option value="BLUE">BLUE</option>
      <option value="GREEN">GREEN</option>
      <option value="YELLOW">YELLOW</option>
    </select>

    <button class="bg-green-600 text-white px-4 py-2 rounded">
      Apply
    </button>

  </form>

  <!-- TABLE -->
  <div class="bg-white rounded-xl shadow overflow-x-auto">

    <table class="w-full text-sm">

      <thead class="bg-gray-200 text-gray-700">
        <tr>
          <th class="p-3">ID</th>
          <th>Name</th>
          <th>Class</th>
          <th>Section</th>
          <th>House Colour</th>
          <th>Actions</th>
        </tr>
      </thead>

      <tbody>

      <% students.forEach(s => { %>
        <tr class="border-b hover:bg-gray-50">

          <td class="p-3"><%= s.id %></td>
          <td><%= s.name %></td>
          <td><%= s.class %></td>
          <td><%= s.section %></td>
          <td><%= s.house %></td>

          <td class="space-x-2">

            <a href="/admin/edit/<%= s.id %>" 
               class="bg-yellow-400 px-3 py-1 rounded text-white">
               Edit
            </a>

            <a href="/admin/delete/<%= s.id %>" 
               onclick="return confirm('Delete?')"
               class="bg-red-500 px-3 py-1 rounded text-white">
               Delete
            </a>

            <a href="/<%= s.pdf %>" target="_blank"
               class="bg-blue-500 px-3 py-1 rounded text-white">
               View
            </a>

          </td>

        </tr>
      <% }) %>

      </tbody>

    </table>

  </div>

</div>

</body>
</html>